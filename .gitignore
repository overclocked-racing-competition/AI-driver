# residual_sac_latest.zip (the residual submission option).
checkpoints/*_steps.zip
checkpoints/*vecnorm*.pkl
checkpoints/*vecnormalize*.pkl
checkpoints/*replay_buffer*
checkpoints/_bc_smoke*.pth

# ── Editor / OS cruft ───────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
